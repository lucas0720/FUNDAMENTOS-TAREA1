digraph G {
  rankdir=LR;
  node [shape = circle];
  node [shape = doublecircle]; "q0,q2" "q2" "q0,q1,q2";
  node [shape = circle];
  secret_node [style=invisible, width=0, height=0, label=""];
  secret_node -> "q0,q2";
  "q0,q2" -> "q0,q1,q2" [label="a"];
  "q0,q2" -> "T" [label="b"];
  "q2" -> "T" [label="a"];
  "q2" -> "T" [label="b"];
  "q0,q1,q2" -> "q0,q1,q2" [label="a"];
  "q0,q1,q2" -> "q2" [label="b"];
  "T" -> "T" [label="a"];
  "T" -> "T" [label="b"];
}
